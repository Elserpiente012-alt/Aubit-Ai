{
  "name": "aubit-desktop-assistant",
  "version": "0.1.0",
  "private": true,
  "author": "Aubit Project",
  "description": "Aubit desktop companion with immersive app and Windows widget shell.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-electron.js",
    "check": "node --check electron/main.js && node --check electron/preload.js && node --check src/widget.js && node --check src/app.js",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.aubit.desktopassistant",
    "productName": "Aubit Desktop",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "images/**/*",
      "models/**/*",
      "*.html",
      "README.md",
      "docs/**/*",
      "!backend/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Aubit-Desktop-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Aubit Desktop"
    }
  }
}
